export const package = {
  name: "toolchain-wrappers"
  version: "0.1.0"
  summary: "Compiler toolchain wrapper scripts delegating to managed LLVM tools"
  homepage: "https://grimoire.mchal.lol/"
  license: "MIT"
  targets: ["linux-x86_64-musl" "linux-aarch64-musl" "linux-x86_64-gnu" "linux-aarch64-gnu" "macos-x86_64-darwin" "macos-aarch64-darwin" "freebsd-x86_64-unknown" "freebsd-aarch64-unknown"]

  sources: {}

  deps: {
    build: { default: ["clang" "llvm"] }
    runtime: []
  }

  bins: {
    cc: "bin/cc"
    "c++": "bin/c++"
    ar: "bin/ar"
    as: "bin/as"
    ld: "bin/ld"
    nm: "bin/nm"
    ranlib: "bin/ranlib"
    size: "bin/size"
    strip: "bin/strip"
    objcopy: "bin/objcopy"
    objdump: "bin/objdump"
    readelf: "bin/readelf"
    strings: "bin/strings"
  }
}

export def build [ctx] {
  mkdir ($ctx.package_dir | path join "bin")
  mkdir ($ctx.package_dir | path join "lib")
  mkdir ($ctx.package_dir | path join "include")
  mkdir ($ctx.package_dir | path join "share")
  mkdir ($ctx.package_dir | path join "sbin")
  mkdir ($ctx.package_dir | path join "libexec")
  mkdir ($ctx.package_dir | path join "etc")

  let is_macos = ($ctx.target | str starts-with "macos-")
  let ld_target = if $is_macos { "/usr/bin/ld" } else { $"($env.LLVM_PREFIX)/bin/lld" }

  let wrappers = {
    cc: $"($env.CLANG_PREFIX)/bin/clang"
    "c++": $"($env.CLANG_PREFIX)/bin/clang++"
    ar: $"($env.LLVM_PREFIX)/bin/llvm-ar"
    as: $"($env.LLVM_PREFIX)/bin/llvm-as"
    ld: $ld_target
    nm: $"($env.LLVM_PREFIX)/bin/llvm-nm"
    ranlib: $"($env.LLVM_PREFIX)/bin/llvm-ranlib"
    size: $"($env.LLVM_PREFIX)/bin/llvm-size"
    strip: $"($env.LLVM_PREFIX)/bin/llvm-strip"
    objcopy: $"($env.LLVM_PREFIX)/bin/llvm-objcopy"
    objdump: $"($env.LLVM_PREFIX)/bin/llvm-objdump"
    readelf: $"($env.LLVM_PREFIX)/bin/llvm-readelf"
    strings: $"($env.LLVM_PREFIX)/bin/llvm-strings"
  }

  let wrappers = if $is_macos {
    $wrappers | merge {
      dsymutil: $"($env.LLVM_PREFIX)/bin/llvm-dsymutil"
      lipo: $"($env.LLVM_PREFIX)/bin/llvm-lipo"
      libtool: $"($env.LLVM_PREFIX)/bin/llvm-libtool-darwin"
      otool: $"($env.LLVM_PREFIX)/bin/llvm-otool"
      install_name_tool: $"($env.LLVM_PREFIX)/bin/llvm-install-name-tool"
    }
  } else {
    $wrappers
  }

  for key in $wrappers {
    let wrapper_target = ($wrappers | get $key)
    sh -c $"
      cat > '($ctx.package_dir | path join 'bin' $key)' << 'WRAPPER_EOF'
#!/usr/bin/env sh
exec '($wrapper_target)' \"\$@\"
WRAPPER_EOF
      chmod +x '($ctx.package_dir | path join 'bin' $key)'
    "
  }
}
